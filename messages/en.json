    "faq": {
      "title": "Frequently Asked Questions",
      "items": [
        {
          "q": "Can I use it without a Parasut account?",
          "a": "Yes! Parasut integration is optional. You can enter your customer and product information manually. However, if you connect Parasut, all your data will sync automatically."
        },
        {
          "q": "How does the WhatsApp integration work?",
          "a": "We use the WhatsApp Business API. When you prepare a proposal, an interactive proposal link is sent to the relevant contact with a single click. The customer can review the proposal and accept, request a revision, or reject it through this link."
        },
        {
          "q": "How does the 14-day trial work?",
          "a": "After signing up, you can use all Professional plan features free for 14 days. No credit card required. When the trial period ends, simply choose a plan."
        },
        {
          "q": "Is my data secure?",
          "a": "All your data is encrypted with SSL/TLS. We use GDPR-compliant infrastructure. Your data is hosted on servers in the Europe (Frankfurt) region."
        }
      ]
    },
