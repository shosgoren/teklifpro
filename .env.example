# ==================== DATABASE ====================
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ==================== NEXT AUTH ====================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==================== SUPABASE ====================
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==================== PARASUT API ====================
# OAuth2 - Her tenant kendi bilgilerini girer (DB'de saklanir)
# Bu env degiskenleri sadece platform seviyesi testler icindir
PARASUT_API_URL="https://api.parasut.com/v4"
PARASUT_AUTH_URL="https://auth.parasut.com/oauth/token"
PARASUT_REDIRECT_URI="http://localhost:3000/api/v1/parasut/callback"

# ==================== WHATSAPP BUSINESS API ====================
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN="teklifpro-webhook-verify"

# ==================== PAYMENT (PayTR) ====================
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_BASE_URL="https://www.paytr.com"

# ==================== EMAIL (Resend) ====================
RESEND_API_KEY=
EMAIL_FROM="noreply@teklifpro.com"

# ==================== IYS ====================
IYS_BRAND_CODE=
IYS_API_KEY=

# ==================== UPSTASH REDIS ====================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==================== SENTRY ====================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ==================== CRON ====================
CRON_SECRET="generate-with-openssl-rand-base64-32"

# ==================== APP ====================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TeklifPro"
NODE_ENV="development"
