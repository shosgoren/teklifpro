// TeklifPro - Parasut Entegrasyonlu Teklif Platformu
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== AUTH & TENANT ====================

model Tenant {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  logo            String?
  email           String
  phone           String?
  address         String?
  taxNumber       String?   @map("tax_number")
  taxOffice       String?   @map("tax_office")
  plan            PlanType  @default(STARTER)
  planPeriod      PlanPeriod @default(MONTHLY) @map("plan_period")
  trialEndsAt     DateTime? @map("trial_ends_at")
  subscriptionId  String?   @map("subscription_id")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Parasut Integration
  parasutCompanyId    String?  @map("parasut_company_id")
  parasutClientId     String?  @map("parasut_client_id")
  parasutClientSecret String?  @map("parasut_client_secret")
  parasutUsername     String?  @map("parasut_username")
  parasutPassword     String?  @map("parasut_password")
  parasutAccessToken  String?  @map("parasut_access_token")
  parasutRefreshToken String?  @map("parasut_refresh_token")
  parasutTokenExpiry  DateTime? @map("parasut_token_expiry")
  parasutSyncEnabled  Boolean  @default(false) @map("parasut_sync_enabled")
  parasutLastSyncAt   DateTime? @map("parasut_last_sync_at")

  // WhatsApp Integration
  whatsappPhoneId     String?  @map("whatsapp_phone_id")
  whatsappAccessToken String?  @map("whatsapp_access_token")
  whatsappBusinessId  String?  @map("whatsapp_business_id")

  // Bank Accounts (JSON array: [{bankName, branchName, accountHolder, iban, currency}])
  bankAccounts    Json?    @map("bank_accounts")

  // Smart Follow-up
  smartFollowupEnabled    Boolean   @default(false) @map("smart_followup_enabled")
  followupDaysAfterView   Int       @default(3)     @map("followup_days_after_view")
  followupMessage         String?   @map("followup_message")
  followupMaxReminders    Int       @default(2)     @map("followup_max_reminders")

  // Relations
  users               User[]
  customers            Customer[]
  products             Product[]
  proposals            Proposal[]
  proposalTemplates    ProposalTemplate[]
  auditLogs            AuditLog[]
  parasutSyncLogs      ParasutSyncLog[]

  @@map("tenants")
}

enum PlanType {
  STARTER
  PROFESSIONAL
}

enum PlanPeriod {
  MONTHLY
  YEARLY
}

model User {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  email         String
  name          String
  phone         String?
  password      String?
  avatar        String?
  role          UserRole  @default(USER)
  emailVerified DateTime? @map("email_verified")
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  isActive      Boolean   @default(true) @map("is_active")
  preferences   Json?     @map("preferences")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  tenant                  Tenant    @relation(fields: [tenantId], references: [id])
  proposals               Proposal[]
  auditLogs               AuditLog[]
  emailVerificationTokens EmailVerificationToken[]
  customerNotes           CustomerNote[]

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  USER
  VIEWER
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("email_verification_tokens")
}

// ==================== CUSTOMERS (Parasut Sync) ====================

model Customer {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  parasutId         String?   @map("parasut_id")

  // Company Info
  name              String
  shortName         String?   @map("short_name")
  companyType       CustomerType @default(COMPANY) @map("company_type")
  taxNumber         String?   @map("tax_number")
  taxOffice         String?   @map("tax_office")

  // Contact Info
  email             String?
  phone             String?
  fax               String?
  website           String?

  // Address
  address           String?
  city              String?
  district          String?
  postalCode        String?   @map("postal_code")
  country           String?   @default("TR")

  // Financial
  balance           Decimal   @default(0) @db.Decimal(15, 2)
  currency          String    @default("TRY")

  // Branding
  logo              String?

  // Metadata
  notes             String?
  tags              String[]
  isActive          Boolean   @default(true) @map("is_active")
  lastSyncAt        DateTime? @map("last_sync_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  contacts          CustomerContact[]
  proposals         Proposal[]
  customerNotes     CustomerNote[]

  @@unique([tenantId, parasutId])
  @@index([tenantId, name])
  @@map("customers")
}

enum CustomerType {
  COMPANY
  INDIVIDUAL
}

model CustomerContact {
  id          String    @id @default(cuid())
  customerId  String    @map("customer_id")
  name        String
  title       String?
  email       String?
  phone       String?
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  customer    Customer  @relation(fields: [customerId], references: [id])
  proposals   Proposal[]

  @@map("customer_contacts")
}

// ==================== CUSTOMER NOTES ====================

model CustomerNote {
  id          String    @id @default(cuid())
  customerId  String    @map("customer_id")
  userId      String    @map("user_id")
  content     String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  customer    Customer  @relation(fields: [customerId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([customerId, createdAt])
  @@map("customer_notes")
}

// ==================== PRODUCTS (Parasut Sync) ====================

enum ProductType {
  COMMERCIAL      // Ticari - satılabilir, tekliflere eklenen
  RAW_MATERIAL    // Hammadde
  SEMI_FINISHED   // Yarı Mamül
  CONSUMABLE      // Sarf Malzeme (ambalaj, etiket vs.)
}

model Product {
  id              String      @id @default(cuid())
  tenantId        String      @map("tenant_id")
  parasutId       String?     @map("parasut_id")

  code            String?
  name            String
  description     String?
  category        String?
  unit            String      @default("Adet")
  productType     ProductType @default(COMMERCIAL) @map("product_type")

  // Pricing
  listPrice       Decimal     @default(0) @db.Decimal(15, 2) @map("list_price")
  currency        String      @default("TRY")
  vatRate         Decimal     @default(20) @db.Decimal(5, 2) @map("vat_rate")

  // Cost (calculated from BOM or manually entered)
  costPrice       Decimal     @default(0) @db.Decimal(15, 2) @map("cost_price")
  laborCost       Decimal     @default(0) @db.Decimal(15, 2) @map("labor_cost")
  overheadRate    Decimal     @default(0) @db.Decimal(5, 2) @map("overhead_rate")

  // Stock
  trackStock      Boolean     @default(false) @map("track_stock")
  stockQuantity   Decimal     @default(0) @db.Decimal(15, 2) @map("stock_quantity")
  minStockLevel   Decimal     @default(0) @db.Decimal(15, 2) @map("min_stock_level")

  // Metadata
  imageUrl        String?     @map("image_url")
  isActive        Boolean     @default(true) @map("is_active")
  lastSyncAt      DateTime?   @map("last_sync_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  proposalItems   ProposalItem[]

  // BOM: This product's recipe (what it's made from)
  billOfMaterials BillOfMaterial[]

  // BOM: This product used as material in other products' recipes
  usedInBomItems  BomItem[]

  // Stock movements
  stockMovements  StockMovement[]

  // Supplier relationships
  suppliers       ProductSupplier[]
  priceHistory    PriceHistory[]

  @@unique([tenantId, parasutId])
  @@unique([tenantId, code])
  @@index([tenantId, name])
  @@index([tenantId, productType])
  @@map("products")
}

// ==================== PRICE HISTORY (Fiyat Geçmişi) ====================

model PriceHistory {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  productId   String   @map("product_id")
  field       String   // 'listPrice', 'costPrice', 'laborCost'
  oldValue    Decimal  @db.Decimal(15, 2) @map("old_value")
  newValue    Decimal  @db.Decimal(15, 2) @map("new_value")
  changedBy   String?  @map("changed_by")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
  @@index([tenantId, createdAt])
  @@map("price_history")
}

// ==================== BILL OF MATERIALS (BOM / Reçete) ====================

model BillOfMaterial {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  productId   String    @map("product_id")
  version     Int       @default(1)
  isActive    Boolean   @default(true) @map("is_active")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  product     Product   @relation(fields: [productId], references: [id])
  items       BomItem[]

  @@unique([productId, version])
  @@index([tenantId])
  @@map("bill_of_materials")
}

model BomItem {
  id            String    @id @default(cuid())
  bomId         String    @map("bom_id")
  materialId    String    @map("material_id")
  quantity      Decimal   @default(1) @db.Decimal(15, 4) // Required quantity
  unit          String    @default("Adet")
  wasteRate     Decimal   @default(0) @db.Decimal(5, 2) @map("waste_rate") // Fire oranı %
  notes         String?
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  bom           BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  material      Product        @relation(fields: [materialId], references: [id])

  @@index([bomId])
  @@map("bom_items")
}

// ==================== SUPPLIERS (Tedarikçiler) ====================

model Supplier {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  name          String
  contactName   String?   @map("contact_name")
  phone         String?
  email         String?
  address       String?
  taxNumber     String?   @map("tax_number")
  taxOffice     String?   @map("tax_office")
  notes         String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  products      ProductSupplier[]

  @@index([tenantId, name])
  @@map("suppliers")
}

model ProductSupplier {
  id              String    @id @default(cuid())
  productId       String    @map("product_id")
  supplierId      String    @map("supplier_id")
  unitPrice       Decimal   @default(0) @db.Decimal(15, 2) @map("unit_price")
  currency        String    @default("TRY")
  leadTimeDays    Int?      @map("lead_time_days")
  minOrderQty     Decimal?  @db.Decimal(15, 2) @map("min_order_qty")
  isPreferred     Boolean   @default(false) @map("is_preferred")
  lastPurchaseAt  DateTime? @map("last_purchase_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  product         Product   @relation(fields: [productId], references: [id])
  supplier        Supplier  @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId])
  @@map("product_suppliers")
}

// ==================== STOCK MOVEMENTS (Stok Hareketleri) ====================

enum StockMovementType {
  IN            // Stok girişi
  OUT           // Stok çıkışı
  ADJUSTMENT    // Düzeltme / Sayım
  PRODUCTION_IN // Üretimden giriş
  PRODUCTION_OUT // Üretime çıkış (hammadde tüketimi)
}

model StockMovement {
  id          String            @id @default(cuid())
  tenantId    String            @map("tenant_id")
  productId   String            @map("product_id")
  type        StockMovementType
  quantity    Decimal           @db.Decimal(15, 2)
  unitPrice   Decimal?          @db.Decimal(15, 2) @map("unit_price")
  reference   String?           // Referans (sipariş no, fatura no vs.)
  notes       String?
  createdBy   String?           @map("created_by")
  createdAt   DateTime          @default(now()) @map("created_at")

  product     Product           @relation(fields: [productId], references: [id])

  @@index([tenantId, createdAt])
  @@index([productId, createdAt])
  @@map("stock_movements")
}

// ==================== PROPOSALS ====================

model Proposal {
  id                String          @id @default(cuid())
  tenantId          String          @map("tenant_id")
  userId            String          @map("user_id")
  customerId        String          @map("customer_id")
  contactId         String?         @map("contact_id")
  templateId        String?         @map("template_id")

  // Proposal Info
  proposalNumber    String          @map("proposal_number")
  title             String
  description       String?

  // Status & Tracking
  status            ProposalStatus  @default(DRAFT)
  sentAt            DateTime?       @map("sent_at")
  viewedAt          DateTime?       @map("viewed_at")
  respondedAt       DateTime?       @map("responded_at")
  expiresAt         DateTime?       @map("expires_at")
  viewCount         Int             @default(0) @map("view_count")
  totalViewDuration Int             @default(0) @map("total_view_duration") // seconds

  // Public Access
  publicToken       String          @unique @map("public_token")
  publicUrl         String?         @map("public_url")

  // Financial
  subtotal          Decimal         @default(0) @db.Decimal(15, 2)
  discountType      DiscountType?   @map("discount_type")
  discountValue     Decimal?        @db.Decimal(15, 2) @map("discount_value")
  discountAmount    Decimal         @default(0) @db.Decimal(15, 2) @map("discount_amount")
  vatTotal          Decimal         @default(0) @db.Decimal(15, 2) @map("vat_total")
  grandTotal        Decimal         @default(0) @db.Decimal(15, 2) @map("grand_total")
  currency          String          @default("TRY")

  // Customer Response
  customerNote      String?         @map("customer_note")
  rejectionReason   String?         @map("rejection_reason")
  revisionNote      String?         @map("revision_note")
  signatureData     String?         @map("signature_data") // base64 PNG
  signedAt          DateTime?       @map("signed_at")
  signerName        String?         @map("signer_name")

  // Terms & Conditions
  validityDays      Int             @default(30) @map("validity_days")
  paymentTerms      String?         @map("payment_terms")
  deliveryTerms     String?         @map("delivery_terms")
  notes             String?
  termsConditions   String?         @map("terms_conditions")

  // WhatsApp
  whatsappSentAt    DateTime?       @map("whatsapp_sent_at")
  whatsappMessageId String?         @map("whatsapp_message_id")

  // Parasut Integration
  parasutOfferId    String?         @unique @map("parasut_offer_id")
  parasutLastSyncAt DateTime?       @map("parasut_last_sync_at")

  // Voice Note
  voiceNoteData     String?         @map("voice_note_data")     // base64 audio data
  voiceNoteDuration Int?            @map("voice_note_duration")  // seconds

  // Follow-up tracking
  followupCount     Int             @default(0) @map("followup_count")
  lastFollowupAt    DateTime?       @map("last_followup_at")

  // Metadata
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  user              User            @relation(fields: [userId], references: [id])
  customer          Customer        @relation(fields: [customerId], references: [id])
  contact           CustomerContact? @relation(fields: [contactId], references: [id])
  template          ProposalTemplate? @relation(fields: [templateId], references: [id])
  items             ProposalItem[]
  activities        ProposalActivity[]
  revisions         ProposalRevision[]

  @@unique([tenantId, proposalNumber])
  @@index([tenantId, status])
  @@index([publicToken])
  @@index([parasutOfferId])
  @@map("proposals")
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  REVISION_REQUESTED
  REVISED
  EXPIRED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model ProposalItem {
  id            String    @id @default(cuid())
  proposalId    String    @map("proposal_id")
  productId     String?   @map("product_id")

  sortOrder     Int       @default(0) @map("sort_order")
  name          String
  description   String?
  unit          String    @default("Adet")
  quantity      Decimal   @default(1) @db.Decimal(15, 2)
  unitPrice     Decimal   @default(0) @db.Decimal(15, 2) @map("unit_price")
  discountRate  Decimal   @default(0) @db.Decimal(5, 2) @map("discount_rate")
  vatRate       Decimal   @default(20) @db.Decimal(5, 2) @map("vat_rate")
  lineTotal     Decimal   @default(0) @db.Decimal(15, 2) @map("line_total")

  proposal      Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  product       Product?  @relation(fields: [productId], references: [id])

  @@map("proposal_items")
}

model ProposalActivity {
  id          String            @id @default(cuid())
  proposalId  String            @map("proposal_id")
  type        ActivityType
  description String?
  metadata    Json?
  ipAddress   String?           @map("ip_address")
  userAgent   String?           @map("user_agent")
  isRead      Boolean           @default(false) @map("is_read")
  createdAt   DateTime          @default(now()) @map("created_at")

  proposal    Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
  @@map("proposal_activities")
}

enum ActivityType {
  CREATED
  UPDATED
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  REVISION_REQUESTED
  REVISED
  EXPIRED
  CANCELLED
  WHATSAPP_SENT
  WHATSAPP_DELIVERED
  WHATSAPP_READ
  LINK_CLICKED
  FOLLOWUP_SENT
}

model ProposalRevision {
  id          String    @id @default(cuid())
  proposalId  String    @map("proposal_id")
  version     Int
  snapshot    Json      // Full proposal snapshot
  changedBy   String    @map("changed_by")
  changeNote  String?   @map("change_note")
  createdAt   DateTime  @default(now()) @map("created_at")

  proposal    Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([proposalId, version])
  @@map("proposal_revisions")
}

model ProposalTemplate {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  content     Json      // Template structure
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  proposals   Proposal[]

  @@map("proposal_templates")
}

// ==================== PARASUT SYNC ====================

model ParasutSyncLog {
  id          String          @id @default(cuid())
  tenantId    String          @map("tenant_id")
  entityType  String          @map("entity_type") // customer, product, invoice
  direction   SyncDirection
  status      SyncStatus
  recordCount Int             @default(0) @map("record_count")
  errorCount  Int             @default(0) @map("error_count")
  errors      Json?
  startedAt   DateTime        @default(now()) @map("started_at")
  completedAt DateTime?       @map("completed_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId, startedAt])
  @@map("parasut_sync_logs")
}

enum SyncDirection {
  PULL    // Parasut -> TeklifPro
  PUSH    // TeklifPro -> Parasut
  BIDIRECTIONAL
}

enum SyncStatus {
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  userId      String?   @map("user_id")
  action      String
  entity      String
  entityId    String?   @map("entity_id")
  oldData     Json?     @map("old_data")
  newData     Json?     @map("new_data")
  metadata    Json?
  ipAddress   String?   @map("ip_address")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
